{
  "name": "memeautobuy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "NODE_OPTIONS=--dns-result-order=ipv4first tsx src/_setup.ts",
    "doctor": "NODE_OPTIONS=--dns-result-order=ipv4first tsx src/_doctor.ts",
    "install:onchainos": "curl -sSL https://raw.githubusercontent.com/okx/onchainos-skills/main/install.sh | sh",
    "dev": "NODE_OPTIONS=--dns-result-order=ipv4first tsx watch src/main.ts",
    "start": "node --dns-result-order=ipv4first --import tsx src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "1.95.0",
    "bs58": "6.0.0",
    "dotenv": "16.4.5",
    "pino": "9.5.0",
    "pino-pretty": "11.3.0",
    "pm2": "6.0.14",
    "tsx": "4.19.0"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "typescript": "^5.6.0"
  }
}
